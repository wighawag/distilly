{
	"name": "distilly",
	"version": "0.0.0",
	"description": "Distill HTML into clean, token-efficient markdown for agents. Pure, local, no network. Engine vendored and decoupled from wevm/curl.md.",
	"license": "MIT",
	"keywords": [
		"html",
		"markdown",
		"html-to-markdown",
		"extraction",
		"readability",
		"agents"
	],
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"dependencies": {
	},
	"devDependencies": {
		"@types/node": "^25.2.0",
		"as-soon": "^0.1.5",
		"tsx": "^4.21.0",
		"typescript": "^5.3.3",
		"vitest": "^4.0.18"
	},
	"scripts": {
		"build": "tsc",
		"dev": "as-soon -w src pnpm build",
		"test": "vitest run",
		"test:watch": "vitest"
	}
}
